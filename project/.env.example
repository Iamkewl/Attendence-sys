# ── Core ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://attendance:attendance@localhost:5432/attendance
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Celery ────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── API Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── HMAC (Device Auth) ───────────────────────────────
HMAC_ALGO=sha256
NONCE_TTL_SECONDS=60

# ── Scheduler ─────────────────────────────────────────
SNAPSHOT_INTERVAL_MINUTES=10

# ── AI Pipeline ───────────────────────────────────────
INSIGHTFACE_PROVIDER=CPUExecutionProvider
INSIGHTFACE_DET_SIZE=960
RECOGNITION_BACKEND=insightface
YOLO_MODEL_PATH=yolov8n-face.pt
YOLO_MODEL_PATH_FINE=models/yolov8m-face.pt

# ── Face Matching ─────────────────────────────────────
FACE_MATCH_THRESHOLD=0.85
FACE_MATCH_RELAXED_THRESHOLD=0.78
FACE_MATCH_MARGIN=0.08
MIN_FACE_SIZE_PX=48
MIN_FACE_AREA_RATIO=0.0025
MIN_BLUR_VARIANCE=45.0
MIN_FACE_QUALITY_SCORE=0.18

# ── Burst Capture ─────────────────────────────────────
BURST_CAPTURE_COUNT=8
BURST_CAPTURE_GAP_MS=120
MAX_DEBUG_IMAGES=5

# ── SAHI ──────────────────────────────────────────────
ENABLE_DUAL_PASS_SAHI=true
SAHI_FINE_SLICE_SIZE=320
SAHI_FINE_OVERLAP=0.3

# ── Multi-Pose & AdaFace ─────────────────────────────
ENABLE_ADAFACE=true
ADAFACE_MODEL_PATH=models/adaface_ir101_webface12m.onnx

# ── Preprocessing & Super-Resolution ─────────────────
ENABLE_PREPROCESSING=true
ENABLE_SUPER_RESOLUTION=true
SUPER_RESOLUTION_MODEL_PATH=models/realesrgan_x4.onnx
MIN_FACE_UPSCALE_PX=64

# ── Liveness ──────────────────────────────────────────
ENABLE_LIVENESS_CHECK=true
LIVENESS_MOTION_THRESHOLD=2.5
LIVENESS_FLOW_MIN_MAGNITUDE=0.8
LIVENESS_SPOOF_THRESHOLD=0.5
LIVENESS_ANTI_SPOOF_MODEL_PATH=models/anti_spoof_2.7_80x80.onnx

# ── Rate Limiting ─────────────────────────────────────
INGEST_RATE_LIMIT_SECONDS=30

# ── Phase 1 ───────────────────────────────────────────
ENABLE_YOLOV12=false
YOLOV12_MODEL_PATH=models/yolov12l.pt

# ── Phase 2 ───────────────────────────────────────────
ENABLE_LVFACE=false
LVFACE_MODEL_PATH=models/lvface_base.onnx
RECOGNITION_FUSION_MODE=weighted_average
ARCFACE_WEIGHT=0.35
ADAFACE_WEIGHT=0.30
LVFACE_WEIGHT=0.35

# ── Phase 3 ───────────────────────────────────────────
ENABLE_TRITON=false
TRITON_URL=localhost:8001

# ── Phase 4 ───────────────────────────────────────────
ENABLE_TRACKING=false
ENABLE_CROSS_CAMERA_REID=false
ENABLE_PERSON_BOX_ESTIMATION=true
REID_MODEL_PATH=models/osnet_x1_0.onnx

# ── Phase 5 ───────────────────────────────────────────
ENABLE_CODEFORMER=false
CODEFORMER_MODEL_PATH=models/codeformer_v0.1.0.onnx

# ── Phase 6 ───────────────────────────────────────────
ENABLE_DISKANN=false
ANN_RETRIEVAL_BACKEND=numpy

# ── Phase 7 ───────────────────────────────────────────
ENABLE_RPPG_LIVENESS=false
ENABLE_FLASH_LIVENESS=false

# ── Phase 8 ───────────────────────────────────────────
ENABLE_AUTO_TEMPLATE_REFRESH=false
ENABLE_FAIRNESS_AUDIT=false
ENABLE_DATA_RETENTION=false
ENABLE_CAMERA_DRIFT_DETECTION=false
AUTO_REFRESH_REQUIRE_LIVENESS=true
